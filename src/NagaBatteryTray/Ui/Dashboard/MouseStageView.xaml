<UserControl x:Class="NagaBatteryTray.Ui.Dashboard.MouseStageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:motion="clr-namespace:NagaBatteryTray.Ui">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <DataTemplate x:Key="ChipTemplate">
      <Border Margin="0,3" MinWidth="150"
              RenderTransformOrigin="0.5,0.5"
              MouseEnter="OnChipEnter" MouseLeave="OnChipLeave" Cursor="Hand"
              Focusable="True" KeyboardNavigation.IsTabStop="True"
              AutomationProperties.Name="{Binding Label, StringFormat=Button {0}}"
              PreviewMouseLeftButtonDown="OnChipPressDown" PreviewMouseLeftButtonUp="OnChipPressUp"
              MouseLeftButtonUp="OnChipClick" KeyUp="OnChipKeyUp"
              IsEnabled="{Binding DataContext.DeviceOnline, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <Border.RenderTransform>
          <ScaleTransform/>
        </Border.RenderTransform>
        <Border.Style>
          <Style TargetType="Border" BasedOn="{StaticResource ChipBorder}">
            <!-- stroke diet: at rest the chip border is invisible (thickness kept so state
                 changes never shift layout); a stroke only appears as a state signal below -->
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource App.Accent}"/>
              </DataTrigger>
              <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource App.Accent}"/>
                <Setter Property="Background" Value="{DynamicResource App.AccentSoft}"/>
              </DataTrigger>
              <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource App.Accent}"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel>
          <TextBlock Style="{DynamicResource LabelText}" Text="{Binding Label, StringFormat=Button {0}}"/>
          <Grid HorizontalAlignment="Left">
            <Border Background="{DynamicResource App.ChipFill}" BorderBrush="{DynamicResource App.ChipStroke}"
                    BorderThickness="1,1,1,2" CornerRadius="4" Padding="6,1">
              <TextBlock TextTrimming="CharacterEllipsis" ToolTip="{Binding BindingText}"
                         FontWeight="SemiBold" Foreground="{DynamicResource App.TextPrimary}">
                <TextBlock.Style>
                  <Style TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
                    <Setter Property="Text" Value="{Binding BindingText}"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                        <Setter Property="Text" Value="press a key…"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </Border>
            <!-- verified-apply accent flash: fires once per successful write (Status -> "Applied"),
                 restart-on-retrigger is correct here since each apply is its own event -->
            <Border BorderBrush="{DynamicResource App.Accent}" BorderThickness="1.5" CornerRadius="4"
                    Opacity="0" IsHitTestVisible="False">
              <Border.Style>
                <Style TargetType="Border">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Status}" Value="Applied">
                      <DataTrigger.EnterActions>
                        <BeginStoryboard>
                          <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                              <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                              <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="1" EasingFunction="{x:Static motion:Motion.EaseOut}"/>
                              <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="0" EasingFunction="{x:Static motion:Motion.EaseOut}"/>
                            </DoubleAnimationUsingKeyFrames>
                          </Storyboard>
                        </BeginStoryboard>
                      </DataTrigger.EnterActions>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
            </Border>
          </Grid>
          <TextBlock Style="{DynamicResource SubtleText}" Text="{Binding Status}" FontSize="10"/>
          <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Hidden"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding CanUndo}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>
            <Button Content="Undo" Click="OnUndo" FontSize="10" Padding="6,1"
                    Visibility="{Binding CanUndo, Converter={StaticResource BoolToVis}}">
              <Button.Style>
                <Style TargetType="Button">
                  <Style.Triggers>
                    <!-- appearance-only fade: the action row itself stays instant on hover/focus
                         (frequency rule - no motion on a frequently hovered element), so only the
                         Undo button's own CanUndo-triggered reveal gets the 150ms fade-in -->
                    <DataTrigger Binding="{Binding CanUndo}" Value="True">
                      <DataTrigger.EnterActions>
                        <BeginStoryboard>
                          <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1"
                                             Duration="0:0:0.15" EasingFunction="{x:Static motion:Motion.EaseOut}"/>
                          </Storyboard>
                        </BeginStoryboard>
                      </DataTrigger.EnterActions>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
            </Button>
            <Button Content="Disable" Click="OnDisable" FontSize="10" Padding="6,1" Margin="4,0,0,0"/>
            <Button Content="Default" Click="OnDefault" FontSize="10" Padding="6,1" Margin="4,0,0,0"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="180"/>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="180"/>
      <ColumnDefinition Width="230"/>
    </Grid.ColumnDefinitions>

    <ItemsControl Grid.Column="0" x:Name="LeftChips" VerticalAlignment="Center"
                  ItemTemplate="{StaticResource ChipTemplate}"/>

    <!-- stage: silhouette + grid keys -->
    <Viewbox Grid.Column="1" Stretch="Uniform" MaxHeight="440">
      <Viewbox.Style>
        <Style TargetType="Viewbox">
          <Style.Triggers>
            <DataTrigger Binding="{Binding DeviceOnline}" Value="False">
              <Setter Property="Opacity" Value="0.45"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Viewbox.Style>
      <Canvas Width="400" Height="220">
        <!-- left-side profile, nose facing left (the thumb-grid side the user actually sees).
             The wheel is drawn FIRST: seen along its axle it is a disc, and the opaque shell
             painted over it leaves only the arc poking above the front-top edge visible. -->
        <Ellipse Canvas.Left="64" Canvas.Top="84" Width="32" Height="32"
                 Fill="{DynamicResource App.CanvasBrush}"/>
        <Ellipse Canvas.Left="64" Canvas.Top="84" Width="32" Height="32"
                 Fill="{DynamicResource App.ChipFill}" Stroke="{DynamicResource App.ChipStroke}" StrokeThickness="1.5"/>
        <!-- body shell: low nose, arch peaking ~60% back, rounded tail, flat base. The theme
             fills are translucent tints, so the shell stacks an opaque CanvasBrush base under
             the CardFill tint — the mouse reads as a card-surface shape, not a wire ghost -->
        <Path Fill="{DynamicResource App.CanvasBrush}"
              Data="M 34,200 C 22,190 16,152 26,126 C 32,110 42,103 54,101 C 112,84 168,46 246,38
                    C 292,40 330,62 358,96 C 372,118 380,146 376,170 C 372,188 366,196 354,200 Z"/>
        <Path StrokeThickness="1.5" Stroke="{DynamicResource App.CardStroke}" Fill="{DynamicResource App.CardFill}"
              Data="M 34,200 C 22,190 16,152 26,126 C 32,110 42,103 54,101 C 112,84 168,46 246,38
                    C 292,40 330,62 358,96 C 372,118 380,146 376,170 C 372,188 366,196 354,200 Z"/>
        <!-- front click seam, nose ridge to the wheel well -->
        <Path StrokeThickness="1" Stroke="{DynamicResource App.CardStroke}" Opacity="0.55"
              Data="M 27,128 C 42,124 56,114 64,104"/>
        <Ellipse Canvas.Left="50" Canvas.Top="55" Width="300" Height="140"
                 Fill="{DynamicResource App.GlowSoft}" IsHitTestVisible="False"/>
        <!-- thumb side panel: 12 keys in the hardware's own layout — 4 columns front-to-back,
             each numbered bottom-up (top row 3 6 9 12, middle 2 5 8 11, bottom 1 4 7 10; the
             item order comes from Bind) — raked -8° to follow the shell line -->
        <Canvas Canvas.Left="86" Canvas.Top="88" Width="190" Height="88"
                RenderTransformOrigin="0.5,0.5">
          <Canvas.RenderTransform><RotateTransform Angle="-7"/></Canvas.RenderTransform>
          <Rectangle Width="190" Height="88" RadiusX="10" RadiusY="10"
                     Fill="{DynamicResource App.CardFill}" Stroke="{DynamicResource App.CardStroke}" StrokeThickness="1"/>
          <ItemsControl x:Name="GridKeys" Canvas.Left="3" Canvas.Top="2">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><UniformGrid Columns="4"/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Width="40" Height="22" Margin="3" CornerRadius="4"
                        RenderTransformOrigin="0.5,0.5"
                        MouseEnter="OnKeyEnter" MouseLeave="OnKeyLeave"
                        PreviewMouseLeftButtonDown="OnChipPressDown" PreviewMouseLeftButtonUp="OnChipPressUp"
                        MouseLeftButtonUp="OnChipClick"
                        IsEnabled="{Binding DataContext.DeviceOnline, RelativeSource={RelativeSource AncestorType=UserControl}}">
                  <Border.RenderTransform>
                    <ScaleTransform/>
                  </Border.RenderTransform>
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="{DynamicResource App.ChipFill}"/>
                      <Setter Property="BorderBrush" Value="Transparent"/>
                      <Setter Property="BorderThickness" Value="1"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                          <Setter Property="BorderBrush" Value="{DynamicResource App.Accent}"/>
                          <Setter Property="Background" Value="{DynamicResource App.AccentSoft}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <TextBlock Text="{Binding Label}" FontSize="10" HorizontalAlignment="Center"
                             VerticalAlignment="Center" Foreground="{DynamicResource App.TextSecondary}"/>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Canvas>
      </Canvas>
    </Viewbox>

    <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8"
               Text="mouse offline — reconnect to edit">
      <TextBlock.Style>
        <Style TargetType="TextBlock" BasedOn="{StaticResource SubtleText}">
          <Setter Property="Visibility" Value="Collapsed"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding DeviceOnline}" Value="False">
              <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </TextBlock.Style>
    </TextBlock>

    <ItemsControl Grid.Column="2" x:Name="RightChips" VerticalAlignment="Center"
                  ItemTemplate="{StaticResource ChipTemplate}"/>

    <!-- right rail -->
    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="8,0,0,0">
      <Border Style="{DynamicResource CardBorder}" Margin="0,0,0,10">
        <StackPanel>
          <StackPanel Orientation="Horizontal">
            <TextBlock Style="{DynamicResource NumeralText}" Text="{Binding DpiText}"/>
            <TextBlock Style="{DynamicResource LabelText}" Text="DPI" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
          </StackPanel>
          <!-- SmallChange: WPF's 0.1 default on a 0..1 log slider makes one arrow press jump DPI
               ~77% — 0.02 keeps keyboard steps near the old 100-DPI granularity at typical values -->
          <Slider Minimum="0" Maximum="1" SmallChange="0.02" LargeChange="0.1"
                  Value="{Binding DpiSliderPos, Mode=TwoWay}" IsEnabled="{Binding DevicePresent}"
                  Thumb.DragCompleted="OnDpiDragCompleted" KeyUp="OnDpiSliderKeyUp"/>
          <ItemsControl ItemsSource="{Binding Presets}" Margin="0,8,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <DockPanel Margin="0,2">
                  <Button DockPanel.Dock="Right" Content="✕" FontSize="9" Padding="4,0"
                          Click="OnRemovePreset" Opacity="0.5"/>
                  <Button Click="OnApplyPreset" Background="Transparent" BorderThickness="0"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                          IsEnabled="{Binding DataContext.DevicePresent, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <StackPanel Orientation="Horizontal">
                      <Ellipse Width="7" Height="7" VerticalAlignment="Center">
                        <Ellipse.Style>
                          <Style TargetType="Ellipse">
                            <!-- base Fill lives in the style: a local Fill on the element would
                                 outrank the IsActive trigger and the dot could never turn accent -->
                            <Setter Property="Fill" Value="{DynamicResource App.TextSecondary}"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Fill" Value="{DynamicResource App.Accent}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Ellipse.Style>
                      </Ellipse>
                      <TextBlock Style="{DynamicResource BodyText}" Text="{Binding Value}" Margin="7,0,0,0"/>
                      <TextBlock Style="{DynamicResource BodyText}" Text=" ✓" Foreground="{DynamicResource App.Accent}"
                                 Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                  </Button>
                </DockPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <DockPanel Margin="0,6,0,0">
            <Button DockPanel.Dock="Right" Content="+" Click="OnAddPreset" Padding="8,2" Margin="6,0,0,0"/>
            <ui:NumberBox x:Name="NewPresetBox" Minimum="100" Maximum="30000" SmallChange="50"
                          MaxDecimalPlaces="0" PlaceholderText="add"/>
          </DockPanel>
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource CardBorder}">
        <StackPanel>
          <DockPanel LastChildFill="False">
            <TextBlock Style="{DynamicResource LabelText}" Text="PROFILE"/>
            <ui:Button DockPanel.Dock="Right" Content="↻" Padding="6,2"
                       Click="OnRefreshLiveness" Opacity="0.6"/>
          </DockPanel>
          <TextBlock Style="{DynamicResource BodyText}" Text="{Binding ProfileTitle}" FontWeight="SemiBold"/>
          <TextBlock Style="{DynamicResource SubtleText}" Text="{Binding ProfileDetail}" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>
    </StackPanel>
  </Grid>
</UserControl>
