<Window x:Class="NagaBatteryTray.Ui.PopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
    AllowsTransparency="True" Background="Transparent"
    SizeToContent="WidthAndHeight" Topmost="True">
  <Border Width="264" Background="{DynamicResource App.CanvasBrush}" CornerRadius="12" Padding="15" Margin="12"
          BorderBrush="{DynamicResource App.CardStroke}" BorderThickness="1">
    <StackPanel>
      <DockPanel>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#x1F40D;" FontSize="13" Foreground="{DynamicResource App.Accent}" VerticalAlignment="Center"/>
          <TextBlock Text="Naga V2 Pro" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource App.TextPrimary}"
                     VerticalAlignment="Center" Margin="5,0,0,0"/>
        </StackPanel>
        <TextBlock Text="{Binding Status}" DockPanel.Dock="Right" HorizontalAlignment="Right"
                   VerticalAlignment="Center" Foreground="{DynamicResource App.TextSecondary}" FontSize="11"/>
      </DockPanel>
      <StackPanel Orientation="Horizontal" Margin="0,8,0,6">
        <TextBlock Text="{Binding PercentText}" FontWeight="ExtraLight" FontSize="40"
                   Foreground="{DynamicResource App.Numeral}" Margin="0,-4,0,0"/>
        <Border Background="{DynamicResource App.ChipFill}" CornerRadius="12" Padding="8,3" Margin="10,6,0,0"
                VerticalAlignment="Center"
                Visibility="{Binding Charging, Converter={StaticResource BoolToVis}}">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="Flash24" FontSize="13" Foreground="{Binding Accent}" VerticalAlignment="Center"/>
            <TextBlock Text="Charging" FontSize="11" Foreground="{Binding Accent}"
                       VerticalAlignment="Center" Margin="3,0,0,0"/>
          </StackPanel>
        </Border>
      </StackPanel>
      <Border Height="6" CornerRadius="3" Background="{DynamicResource App.ChipFill}" Width="234" HorizontalAlignment="Left">
        <Border CornerRadius="3" Background="{Binding Accent}" HorizontalAlignment="Left"
                Width="{Binding BarPixelWidth}"/>
      </Border>
      <TextBlock Text="{Binding ProfileText}" FontSize="10" Margin="0,8,0,0"
                 Foreground="{DynamicResource App.TextSecondary}"
                 Visibility="{Binding HasProfile, Converter={StaticResource BoolToVis}}"/>
      <Grid Margin="0,12,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="8"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ui:Button Grid.Column="0" Content="Refresh" Click="OnRefresh" FontSize="12"
                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,7"/>
        <ui:Button Grid.Column="2" Content="Open dashboard" Click="OnSettings" FontSize="12"
                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,7"/>
      </Grid>
    </StackPanel>
  </Border>
</Window>
